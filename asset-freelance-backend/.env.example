# Copy this file to .env and fill in the values

# Generate with:
# python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('your-password'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$replace-this-with-a-real-bcrypt-hash

# openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

DATABASE_URL=sqlite:///./database.db
ACCESS_TOKEN_EXPIRE_MINUTES=30
UPLOADS_DIR=uploads

# SMTP - Configurações para envio de e-mail (pesquisa de satisfação)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-de-app
SMTP_RECIPIENT=destinatario@email.com
