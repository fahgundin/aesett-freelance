# Copy this file to .env and fill in the values

# Generate with:
# python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('your-password'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$replace-this-with-a-real-bcrypt-hash

# openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

DATABASE_URL=sqlite:///./database.db
ACCESS_TOKEN_EXPIRE_MINUTES=30
UPLOADS_DIR=uploads
